ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
MAX_FILE_SIZE_MB=10
UPLOAD_TTL_MINUTES=60

# === Portas no host (sequência dedicada p/ não conflitar com outros projetos) ===
WEB_PORT=8100
API_PORT=8101

# URL da API vista pelo BROWSER (não pelo container). Embutida no build do frontend.
# Se mudar API_PORT, mude aqui também e rode: docker compose build web
VITE_API_URL=http://localhost:8101
